POSTGRES_DB=shoppinglist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Same-origin public URL the browser will use to reach the API.
# The host Nginx proxy routes /items on this domain to the backend
# container, so this should be your real domain over https once you have one.
VITE_API_URL=https://your-domain.example.com
